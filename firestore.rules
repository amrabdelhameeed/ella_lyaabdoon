rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection - for managing sub-admins
    match /admins/{deviceId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // Notification requests - sub-admins submit, super admin approves
    match /notification_requests/{requestId} {
      allow read, write: if true;
    }

    // Notification history - stores all sent notifications
    match /notification_history/{historyId} {
      allow create: if true;  // Allow creating history entries
      allow read: if true;    // Allow reading history
      allow update: if false; // Prevent modification for data integrity
      allow delete: if false; // Prevent deletion for audit trail
    }

    // Devices collection - for FCM tokens
    match /devices/{deviceId} {
      allow read, write: if true;
    }

    // Suggestions collection with validation
    match /suggestions/{suggestionId} {
      allow create: if request.resource.data.keys().hasAll([
        'title',
        'description',
        'source'
      ])
      && request.resource.data.title is string
      && request.resource.data.description is string
      && request.resource.data.source is string;

      allow read, update, delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }

  }
}